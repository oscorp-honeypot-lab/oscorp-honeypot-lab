{
  "id": "oscorp-cowrie-ndjson-pipeline",
  "name": "OSCORP - Cowrie Pipeline Orchestration",
  "description": "Fase 30: n8n invoca al worker trazable y agenda reportes diarios/semanales.",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "0a8f2b49-4b34-49d9-9121-5fb0b43e8d0a",
