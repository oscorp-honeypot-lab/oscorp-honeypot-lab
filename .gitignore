.env

# Runtime data
elasticsearch/data/
n8n/data/
n8n/credentials/*
!n8n/credentials/.gitkeep
kibana/data/

# Live logs generated by Cowrie. Curated evidence belongs in docs/evidencias/.
cowrie/logs/*
!cowrie/logs/.gitkeep

# Local editor and OS noise
.DS_Store
Thumbs.db
*.tmp
*.log

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Generated backups
backups/*
!backups/.gitkeep
