# PostgreSQL
POSTGRES_DB=oscorp
POSTGRES_USER=oscorp
POSTGRES_PASSWORD=oscorp123
POSTGRES_PORT=5433

# n8n
N8N_VERSION=2.15.0
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_ENCRYPTION_KEY=

# Elasticsearch / Kibana
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=cowrie-events
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Cowrie
COWRIE_SSH_PORT=2222
COWRIE_LOG_PATH=cowrie/logs/cowrie.json

# Pipeline
POSTGRES_HOST=postgres
PAYLOAD_BASE_URL=http://payload-server:8080

# Backend
BACKEND_PORT=8000
FRONTEND_PORT=5173
OSCORP_API_ENVIRONMENT=lab
OSCORP_API_LOG_LEVEL=INFO
OSCORP_API_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
OSCORP_API_COOKIE_SECURE=false
OSCORP_API_ADMIN_USERNAME=admin
OSCORP_API_ADMIN_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=put_your_token_here
TELEGRAM_CHAT_ID=put_your_chat_id_here

# VirusTotal
VT_API_KEY=
VIRUSTOTAL_API_KEY=

# VPS opcional
VPS_HOST=
VPS_USER=
VPS_SSH_PORT=22
VPS_REMOTE_DIR=/opt/oscorp-cowrie
VPS_COWRIE_SSH_PORT=2222
VPS_COWRIE_LOG_PATH=/opt/oscorp-cowrie/logs/cowrie.json
